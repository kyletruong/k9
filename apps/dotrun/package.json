{
  "name": "dotrun",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && cp instrument.server.mjs dist/server",
    "deploy": "wrangler deploy",
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
    "dev:convex": "convex dev",
    "lint": "oxlint --type-aware",
    "preview": "NODE_OPTIONS='--import ./instrument.server.mjs' vite preview",
    "test": "vitest run",
    "types": "tsgo --noEmit",
    "types:watch": "tsgo --noEmit --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.31.2",
    "@convex-dev/react-query": "0.1.0",
    "@repo/ui": "workspace:*",
    "@sentry/tanstackstart-react": "10.48.0",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "5.97.0",
    "@tanstack/react-router": "1.168.15",
    "@tanstack/react-router-ssr-query": "1.166.11",
    "@tanstack/react-start": "1.167.27",
    "@tanstack/router-plugin": "1.167.14",
    "@workos-inc/authkit-react": "0.16.1",
    "convex": "1.35.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@rolldown/plugin-babel": "0.2.2",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-query-devtools": "5.97.0",
    "@tanstack/react-router-devtools": "1.166.13",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260411.1",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "jsdom": "29.0.2",
    "vite": "8.0.8",
    "vite-plugin-oxlint": "2.0.1",
    "vitest": "4.1.4",
    "web-vitals": "5.2.0",
    "wrangler": "4.81.1"
  }
}
