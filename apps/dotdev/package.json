{
  "name": "dotdev",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:resume": "pnpm exec typst compile --format pdf ../resume/main.typ public/resume.pdf",
    "deploy": "wrangler versions deploy",
    "dev": "vite dev --port 3001",
    "lint": "oxlint --type-aware",
    "preview": "vite preview",
    "types": "tsgo --noEmit",
    "types:gen": "wrangler types && content-collections build",
    "types:watch": "tsgo --noEmit --watch --preserveWatchOutput",
    "upload": "pnpm run build && wrangler versions upload"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.30.2",
    "@content-collections/core": "0.14.3",
    "@content-collections/vite": "0.2.9",
    "@mdx-js/react": "3.1.1",
    "@react-three/fiber": "9.5.0",
    "@repo/ui": "workspace:*",
    "@shikijs/rehype": "4.0.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-router": "1.168.7",
    "@tanstack/react-start": "1.167.12",
    "@tanstack/router-plugin": "1.167.8",
    "cf-workers-og": "3.0.1",
    "effect": "4.0.0-beta.42",
    "katex": "0.16.44",
    "lucide-react": "1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.2",
    "three": "0.183.2"
  },
  "devDependencies": {
    "@content-collections/cli": "0.1.9",
    "@mdx-js/rollup": "3.1.1",
    "@repo/typescript-config": "workspace:*",
    "@rolldown/plugin-babel": "0.2.2",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-router-devtools": "1.166.11",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.183.1",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-mdx-frontmatter": "5.2.0",
    "typst": "0.10.0-8",
    "vite": "8.0.3",
    "vite-plugin-oxlint": "2.0.1",
    "wrangler": "4.78.0"
  }
}
